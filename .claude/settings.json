{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(pnpm install)",
      "Bash(pnpm dev)",
      "Bash(pnpm build)",
      "Bash(pnpm lint)",
      "Bash(pnpm lint:fix)",
      "Bash(pnpm test)",
      "Bash(pnpm type-check)",
      "Bash(pnpm prisma generate)",
      "Bash(pnpm prisma migrate dev:*)",
      "Bash(pnpm prisma migrate deploy)",
      "Bash(pnpm prisma migrate status)",
      "Bash(pnpm tsx:*)",
      "Bash(pnpm --filter:*)",
      "Bash(turbo run:*)",
      "Bash(docker compose:*)",
      "Bash(docker ps)",
      "Bash(docker logs:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch)",
      "Bash(git show:*)",
      "Bash(mkdir:*)",
      "Bash(ls:*)",
      "Read(docs/*)",
      "Read(.claude/*)",
      "Read(packages/*)",
      "Read(apps/*)",
      "Write(docs/*)",
      "Write(.claude/*)",
      "Edit(docs/*)",
      "Edit(.claude/*)",
      "Edit(apps/*)",
      "Edit(packages/*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(git checkout main)",
      "Bash(npm:*)",
      "Bash(yarn:*)"
    ],
    "ask": [
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git rebase:*)",
      "Bash(git merge:*)",
      "Bash(pnpm prisma migrate reset:*)",
      "Bash(pnpm prisma db push:*)",
      "Bash(docker compose down -v)",
      "Bash(gh pr:*)",
      "Bash(gh issue:*)"
    ]
  },
  "env": {
    "SOCIFLOW_PROJECT_ROOT": "${PWD}"
  }
}
