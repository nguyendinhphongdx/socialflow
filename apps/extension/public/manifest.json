{
  "manifest_version": 3,
  "name": "Sociflow Agent",
  "version": "0.0.0",
  "description": "Sociflow browser automation agent (TikTok, Facebook, Instagram, YouTube)",
  "permissions": [
    "storage",
    "alarms",
    "scripting",
    "activeTab",
    "tabs",
    "webNavigation"
  ],
  "host_permissions": [
    "http://localhost:3000/*",
    "https://*.tiktok.com/*",
    "https://*.facebook.com/*",
    "https://*.instagram.com/*",
    "https://*.youtube.com/*",
    "https://studio.youtube.com/*"
  ],
  "background": {
    "service_worker": "background/index.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://*.tiktok.com/*"],
      "js": ["content-scripts/tiktok.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.facebook.com/*"],
      "js": ["content-scripts/facebook.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.instagram.com/*"],
      "js": ["content-scripts/instagram.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.youtube.com/*", "https://studio.youtube.com/*"],
      "js": ["content-scripts/youtube.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Sociflow Agent"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' http://localhost:3000 ws://localhost:3000 wss://*.sociflow.io https://*.sociflow.io"
  }
}
