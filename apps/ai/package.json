{
  "name": "@sociflow/ai",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --env-file=../../.env --import @swc-node/register/esm-register --watch src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "lint": "eslint . --max-warnings 0",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@nestjs/bullmq": "^11.0.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.0.0",
    "@nestjs/terminus": "^11.0.0",
    "@sentry/node": "^10.53.1",
    "@sentry/profiling-node": "^10.53.1",
    "@sociflow/auth": "workspace:*",
    "@sociflow/common": "workspace:*",
    "@sociflow/internal-client": "workspace:*",
    "@sociflow/prisma": "workspace:*",
    "@sociflow/queue": "workspace:*",
    "bullmq": "^5.0.0",
    "helmet": "^7.2.0",
    "nestjs-cls": "^5.0.0",
    "nestjs-pino": "^4.0.0",
    "openai": "^4.0.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "uuid": "^11.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.33",
    "@types/node": "^22.0.0",
    "express": "^5.2.1",
    "rimraf": "^6.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.9.0",
    "vitest": "^3.0.0"
  }
}
