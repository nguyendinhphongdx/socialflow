{
  "title": "Sociflow — Overview",
  "uid": "sociflow-overview",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "browser",
  "tags": ["sociflow"],
  "annotations": { "list": [] },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "API up",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "up{job=\"sociflow-api\"}", "legendFormat": "api" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ]
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "AI up",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "up{job=\"sociflow-ai\"}", "legendFormat": "ai" }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Postgres connections",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(pg_stat_activity_count)", "legendFormat": "conns" }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Redis memory MB",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "redis_memory_used_bytes / 1024 / 1024", "legendFormat": "MB" }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "HTTP requests / sec (by status)",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum by (status) (rate(http_requests_total{job=~\"sociflow-.*\"}[1m]))", "legendFormat": "{{status}}" }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Request p95 latency (s)",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (le, job) (rate(http_request_duration_seconds_bucket[5m])))", "legendFormat": "{{job}}" }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "BullMQ queue depth",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sociflow_queue_waiting{job=\"sociflow-api\"}", "legendFormat": "waiting/{{queue}}" },
        { "expr": "sociflow_queue_active{job=\"sociflow-api\"}", "legendFormat": "active/{{queue}}" }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Error rate (5xx)",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum by (job) (rate(http_requests_total{status=~\"5..\"}[5m]))", "legendFormat": "{{job}}" }
      ]
    }
  ]
}
