# =========================================
# Sociflow root .env (development)
# Copy → .env, fill values. KHÔNG commit .env.
# =========================================

# Node
NODE_ENV=development

# Postgres (apps/api + apps/ai share)
DATABASE_URL=postgresql://sociflow:dev@localhost:5433/sociflow_dev?schema=public

# Redis (BullMQ + cache)
REDIS_URL=redis://localhost:6380

# Auth
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_AGENT_SECRET=change-me-agent-secret-min-32-chars
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Webhook verify tokens (Meta — phải match value set ở developer dashboard)
FACEBOOK_WEBHOOK_VERIFY_TOKEN=change-me-fb-webhook-verify-min-16

# Stripe (Phase 7 — credits + plan billing)
# Test mode keys từ dashboard.stripe.com/test (đăng ký free, không cần verify để dev).
# Webhook secret = signing secret của endpoint /api/v1/webhook/stripe (Stripe CLI: `stripe listen`).
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
# Đơn giá / credit theo USD cents (1000 = $10.00). Cho mode=payment line_item.
STRIPE_PRICE_PER_CREDIT=1000
# Subscription plan Price IDs (tạo từ Stripe dashboard: Products → Add price).
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_BUSINESS=
STRIPE_PRICE_ID_ENTERPRISE=
# Redirect sau Checkout — bỏ trống = dùng NEXT_PUBLIC_APP_URL/billing?status=...
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=

# Encryption (AES-256-GCM for tokens at rest)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=change-me-32-byte-base64-key

# Internal API token (api ↔ ai authentication)
INTERNAL_TOKEN=change-me-internal-token

# CORS
CORS_ORIGINS=http://localhost:3020,chrome-extension://*

# Cookie
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# Mail (MailHog local)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Sociflow <noreply@sociflow.local>

# Notification — Resend (F-709). Leave RESEND_API_KEY blank in dev = log-only (no real send).
# Get key at https://resend.com — verify sending domain before prod.
RESEND_API_KEY=
NOTIFICATION_FROM_EMAIL=no-reply@sociflow.local
NOTIFICATION_FROM_NAME=Sociflow
# Threshold cảnh báo credit thấp — credits service emit `credit.low` khi balance < threshold
NOTIFICATION_CREDIT_LOW_THRESHOLD=20

# Web Push (VAPID) — generate:
#   node -e "console.log(require('web-push').generateVAPIDKeys())"
# Empty = push disabled (dev log-only). Public key cũng phải set vào FE qua NEXT_PUBLIC_VAPID_PUBLIC_KEY.
NOTIFICATION_VAPID_PUBLIC_KEY=
NOTIFICATION_VAPID_PRIVATE_KEY=
NOTIFICATION_VAPID_SUBJECT=mailto:admin@sociflow.io

# Storage (MinIO local — S3-compatible)
STORAGE_TYPE=s3
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=sociflow-dev
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio12345
S3_PUBLIC_URL=http://localhost:9000/sociflow-dev

# OAuth — Google login (web)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:3000/api/v1/auth/google/callback

# OAuth — YouTube
YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_SECRET=
YOUTUBE_OAUTH_REDIRECT_URI=http://127.0.0.1:3000/api/v1/social-accounts/youtube/callback

# OAuth — Facebook
FACEBOOK_OAUTH_CLIENT_ID=
FACEBOOK_OAUTH_CLIENT_SECRET=
FACEBOOK_OAUTH_REDIRECT_URI=http://127.0.0.1:3000/api/v1/social-accounts/facebook/callback

# OAuth — Instagram (share Meta app)
INSTAGRAM_OAUTH_CLIENT_ID=
INSTAGRAM_OAUTH_CLIENT_SECRET=
INSTAGRAM_OAUTH_REDIRECT_URI=http://127.0.0.1:3000/api/v1/social-accounts/instagram/callback

# OAuth — TikTok (developers.tiktok.com → App → Web Login)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://127.0.0.1:3000/api/v1/social-accounts/tiktok/callback

# AI providers (apps/ai)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
REPLICATE_API_TOKEN=

# Ports
API_PORT=3000
AI_PORT=3001
WEB_PORT=3020

# Web
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3020
NEXT_PUBLIC_SESSION_COOKIE=sf_access

# Web Push public key (FE) — phải khớp với NOTIFICATION_VAPID_PUBLIC_KEY ở BE
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Stripe (apps/web — billing checkout)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Sentry (optional — leave blank in dev to disable)
# Same DSN có thể share giữa apps/api + apps/ai + apps/web hoặc tách project riêng.
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1
# GIT_SHA dùng làm Sentry release — CI inject từ commit hash.
GIT_SHA=
# Source map upload (apps/web build) — chỉ set khi muốn upload Sentry release.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
# Client-side Sentry (apps/web) — DSN public, có thể khác với backend.
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_GIT_SHA=
